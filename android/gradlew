#!/bin/sh
# Gradle wrapper stub - CI uses this to bootstrap Gradle
# Full wrapper JAR should be generated by: gradle wrapper --gradle-version 8.7
# For CI: uses actions/setup-java which provides Gradle

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_HOME="$SCRIPT_DIR"

# Determine the Java command to use
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

exec "$JAVACMD" \
    -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
